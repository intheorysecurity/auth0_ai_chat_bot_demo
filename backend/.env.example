# Auth
AUTH_PROVIDER=auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.aichatbot.local
# Optional: for CIBA (real Auth0 backchannel)
# AUTH0_ISSUER_URL=https://your-tenant.auth0.com/
# AUTH0_CIBA_CLIENT_ID=...
# AUTH0_CIBA_CLIENT_SECRET=...
# AUTH0_CIBA_AUDIENCE=https://api.aichatbot.local
# Optional overrides:
# AUTH0_CIBA_AUTHORIZATION_ENDPOINT=https://your-tenant.auth0.com/bc-authorize
# AUTH0_CIBA_TOKEN_ENDPOINT=https://your-tenant.auth0.com/oauth/token
# OKTA_ISSUER=https://your-org.okta.com/oauth2/default
# OKTA_AUDIENCE=api://default

# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434
# Optional: if set, use this model when `model_id` isn't provided.
# Can be a local model (e.g. "llama3.2") or an Ollama cloud model (e.g. "gpt-oss:20b-cloud").
# OLLAMA_DEFAULT_MODEL=gpt-oss:20b-cloud

# Persistence
DATABASE_URL=sqlite:///./app.db

# Auth0 FGA / OpenFGA
# FGA_API_URL must be a full URL (https://...). Host-only values like api.us1.fga.dev are auto-prefixed with https://
# FGA_API_URL=https://api.us1.fga.dev
# FGA_STORE_ID=...
# FGA_MODEL_ID=...
# Auth (choose one):
# FGA_API_TOKEN=...
# OR client credentials wrapper:
# FGA_API_TOKEN_ISSUER=https://your-fga-issuer.example
# FGA_API_AUDIENCE=https://api.us1.fga.dev/
# FGA_CLIENT_ID=...
# FGA_CLIENT_SECRET=...

# App
FRONTEND_URL=http://localhost:3000
