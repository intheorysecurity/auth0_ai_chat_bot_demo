# =============================================================================
# Auth — JWT validation for the FastAPI API (Auth0 or Okta)
# =============================================================================
AUTH_PROVIDER=auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.aichatbot.local

# Okta (only if AUTH_PROVIDER=okta)
# OKTA_ISSUER=https://your-org.okta.com/oauth2/default
# OKTA_AUDIENCE=api://default

# =============================================================================
# Auth0 CIBA — optional step-up for high-value create_order (chat) ≥ $25 total
# =============================================================================
# Enable only after configuring CIBA on your Auth0 tenant and a dedicated app.
#
# AUTH0_ISSUER_URL — tenant issuer (used to build login_hint JSON for /bc-authorize)
# AUTH0_CIBA_CLIENT_ID / SECRET — application credentials (CIBA-capable app)
# AUTH0_CIBA_AUDIENCE — your API Identifier URL only (same idea as AUTH0_AUDIENCE)
#
# AUTH0_ISSUER_URL=https://your-tenant.us.auth0.com/
# AUTH0_CIBA_CLIENT_ID=
# AUTH0_CIBA_CLIENT_SECRET=
# AUTH0_CIBA_AUDIENCE=https://api.aichatbot.local
#
# Optional: override discovery (defaults: {ISSUER}/bc-authorize and {ISSUER}/oauth/token)
# AUTH0_CIBA_AUTHORIZATION_ENDPOINT=https://your-tenant.us.auth0.com/bc-authorize
# AUTH0_CIBA_TOKEN_ENDPOINT=https://your-tenant.us.auth0.com/oauth/token

# =============================================================================
# LLM providers
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434
# Optional: default when the client does not send model_id
# OLLAMA_DEFAULT_MODEL=llama3.2

# =============================================================================
# Persistence (conversations / tool events)
# =============================================================================
DATABASE_URL=sqlite:///./app.db

# =============================================================================
# Auth0 FGA / OpenFGA — optional order-level authorization
# =============================================================================
# FGA_API_URL must be a full https URL (host-only values are auto-prefixed)
# FGA_API_URL=https://api.us1.fga.dev
# FGA_STORE_ID=
# FGA_MODEL_ID=
#
# Auth: either a static store token OR client credentials for the FGA API
# FGA_API_TOKEN=
#
# FGA_API_TOKEN_ISSUER=https://auth.fga.dev
# FGA_API_AUDIENCE=https://api.us1.fga.dev/
# FGA_CLIENT_ID=
# FGA_CLIENT_SECRET=

# =============================================================================
# App
# =============================================================================
FRONTEND_URL=http://localhost:3000
# Simulated store: GET this URL at startup (JSON array of products; default Fake Store API)
# PRODUCT_CATALOG_URL=https://fakestoreapi.com/products
# Optional: cap product list size (HTTP + list_products tool)
# PRODUCT_LIST_DEFAULT_LIMIT=8
# PRODUCT_LIST_MAX_LIMIT=20
